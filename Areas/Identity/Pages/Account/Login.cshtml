@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<div class="container py-">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="card shadow-sm rounded-4">
                <div class="card-body p-6">
                    <h1 class="h3 fw-bold mb-3">@ViewData["Title"]</h1>


<div class="row">
    <div class="col-md-6">
        <section>
            <form id="account" method="post">
                <p>Use a local account to log in.</p>
                <hr />

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" />
                    <label asp-for="Input.Email"></label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                    <label asp-for="Input.Password"></label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="checkbox mb-3">
                    <label>
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>

                <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>

                <div class="mt-3">
                    <p><a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a></p>
                    <p><a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register as a new user</a></p>
                    <p><a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a></p>
                </div>
                                    <div class="text-center">
                                        <p class="text-muted mb-2">Or register using</p>
                                        @inject IConfiguration Config

                                        @if (Config.GetValue<bool>("Authentication:Google:Enabled"))
                                        {
                                            <form method="post" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                            </form>
                                        }
                                        else
                                        {
                                            <div class="alert alert-secondary text-center mt-3">
                                                Google sign-in is not configured in this system.
                                            </div>
                                        }
                                        @if (Model.ExternalLogins?.Count > 0)
                                        {
                                            <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                                @foreach (var provider in Model.ExternalLogins)
                                                {
                                                    <button type="submit"
                                                            class="w-100 btn btn-outline-success border btn-lg mb-2" style="background-color: #d1e7dd; color: black;" name="provider"
                                                            value="@provider.Name"
                                                            title="Register using @provider.DisplayName">
                                                        Continue with @provider.DisplayName
                                                    </button>
                                                }
                                            </form>
                                        }
                                        else
                                        {
                                            <p class="text-muted small mb-0">
                                                No external authentication services are configured.
                                            </p>
                                        }
                                    </div>
            </form>
        </section>
    </div>
</div>

                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
