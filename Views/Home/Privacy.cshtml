@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="card border-0 shadow-sm rounded-4 bg-light border">
        <div class="card-body p-5">

            <h1 class="display-6 fw-bold mb-3">Privacy Policy</h1>
            <p class="text-muted mb-4">
                The Smart Event Management System is committed to protecting personal information and ensuring that all data
                is processed in a secure and responsible manner. This policy describes how personal data is collected, used,
                stored and protected within the system.
            </p>

            <hr class="my-4" />

            <h5 class="fw-bold">Information Collected</h5>
            <ul>
                <li>Name and contact details (email address and mobile number)</li>
                <li>Account credentials for registered members</li>
                <li>Booking and reservation information</li>
                <li>Event reviews and ratings</li>
                <li>Inquiry messages submitted through the inquiry form</li>
                <li>Technical data such as access time and basic system usage information</li>
            </ul>
            <p class="text-muted">Only information required to provide system functionality is collected.</p>

            <h5 class="fw-bold mt-4">Purpose of Data Collection</h5>
            <ul>
                <li>to create and manage user accounts</li>
                <li>to enable ticket booking and capacity management</li>
                <li>to allow users to submit and track inquiries</li>
                <li>to manage and display event reviews</li>
                <li>to support administrative and operational functions of the council event service</li>
                <li>to improve the quality, reliability and security of the system</li>
            </ul>

            <h5 class="fw-bold mt-4">Lawful and Fair Use of Information</h5>
            <p>
                All personal data is processed in a lawful, fair and transparent manner.
                Information is used only for the purposes stated in this policy and is not used for unrelated activities.
            </p>

            <h5 class="fw-bold mt-4">Data Storage and Security</h5>
            <p>All personal information is stored within a secured database environment. Appropriate technical and organisational measures are applied to protect data against:</p>
            <ul>
                <li>unauthorised access</li>
                <li>accidental loss</li>
                <li>unauthorised modification</li>
                <li>unauthorised disclosure</li>
            </ul>
            <p>Access to administrative and management functions is restricted to authorised staff members only.</p>

            <h5 class="fw-bold mt-4">Sharing of Information</h5>
            <p>
                Personal information is not sold, rented or shared with third parties.
                Information may only be accessed by authorised system administrators and council staff for operational and support purposes.
            </p>

            <h5 class="fw-bold mt-4">User Rights</h5>
            <p>Registered users have the right to:</p>
            <ul>
                <li>access their account information</li>
                <li>update personal details</li>
                <li>request the removal of their account data, subject to operational and legal requirements</li>
            </ul>
            <p>Inquiry records and booking information may be retained for audit and reporting purposes.</p>

            <h5 class="fw-bold mt-4">Use of Reviews and Public Content</h5>
            <p>
                Reviews submitted by registered members are displayed publicly in the system.
                Only review content and ratings are visible to guests.
                Personal identification details of reviewers are not publicly disclosed.
            </p>

            <h5 class="fw-bold mt-4">Cookies and Session Management</h5>
            <p>
                The system uses session-based authentication mechanisms to maintain secure user login sessions.
                Cookies are used only for authentication and system functionality and are not used for advertising or tracking purposes.
            </p>

            <h5 class="fw-bold mt-4">Data Retention</h5>
            <p>
                Personal information is retained only for as long as necessary to support booking management, inquiry tracking,
                reporting and administrative review activities. Outdated or unnecessary data is periodically reviewed and removed
                where appropriate.
            </p>

            <h5 class="fw-bold mt-4">Changes to This Policy</h5>
            <p>
                This privacy policy may be updated to reflect system improvements, legal requirements or changes in operational practices.
                The latest version of the policy will always be available within the system.
            </p>

        </div>
    </div>
</div>
