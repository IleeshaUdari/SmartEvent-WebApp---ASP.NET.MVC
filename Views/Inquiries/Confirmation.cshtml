@model SmartEventWeb.Models.Inquiry

@{
    ViewData["Title"] = "Inquiry Confirmation";
}

<div class="container mt-4" style="max-width: 720px;">
    <h2 class="mb-3">Inquiry Submitted Successfully</h2>

    <div class="alert alert-success shadow-sm">
        <div class="fw-bold mb-1">Reference Code</div>
        <div class="fs-4">@Model.ReferenceCode</div>

        <div class="mt-2">
            <span class="fw-bold">Status:</span>
            @if (Model.IsReplied)
            {
                <span class="badge bg-success ms-2">Replied</span>
            }
            else
            {
                <span class="badge bg-secondary ms-2">Submitted</span>
            }
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="mb-2">
                <div class="text-muted small">Subject</div>
                <div class="fw-semibold">@Model.Subject</div>
            </div>

            <div class="mb-2">
                <div class="text-muted small">Submitted Date</div>
                <div>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
            </div>

            <div class="mb-2">
                <div class="text-muted small">Message</div>
                <div class="border rounded p-2 bg-light">@Model.Message</div>
            </div>

            @if (Model.IsReplied && Model.RepliedDate.HasValue)
            {
                <div class="mt-3">
                    <div class="text-muted small">Replied Date</div>
                    <div>@Model.RepliedDate.Value.ToString("yyyy-MM-dd HH:mm")</div>
                </div>
            }
        </div>
    </div>

    <div class="d-grid gap-2">
        <a class="btn btn-primary" asp-controller="Inquiries" asp-action="Track">
            Track Inquiry
        </a>
        <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">
            Back to Home
        </a>
    </div>
</div>
