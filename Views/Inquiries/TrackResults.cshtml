@model List<SmartEventWeb.Models.Inquiry>

@{
    ViewData["Title"] = "Inquiry Tracking Results";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Tracking Results</h2>
        <a class="btn btn-outline-primary" asp-controller="Inquiries" asp-action="Track">
            New Search
        </a>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-warning shadow-sm">
            No matching inquiries found. Please check the reference code, email, or mobile number.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>Subject</th>
                                <th>Status</th>
                                <th>Submitted</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.ReferenceCode</td>
                                    <td>@item.Subject</td>
                                    <td>
                                        @if (item.IsReplied)
                                        {
                                            <span class="badge bg-success">Replied</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Submitted</span>
                                        }
                                    </td>
                                    <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="text-muted small mt-2">
                    Display includes reference code, subject, status, and submission date for tracking purposes.
                </div>
            </div>
        </div>
    }
</div>
