@model SmartEventWeb.Models.GuestEventSearchVM
@{
    ViewData["Title"] = "Guest Event Search";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0">Guest Event Search</h2>
            <p class="text-muted mb-0">Restricted view: only name, date, venue, and availability.</p>
        </div>
        <a class="btn btn-outline-primary"
           asp-area="Identity" asp-page="/Account/Register">
            Register to book
        </a>
    </div>

    <div class="card shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <form method="get" asp-action="GuestSearch" asp-controller="Events" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Keyword (Event Name)</label>
                    <input name="keyword" value="@Model.Keyword" class="form-control" placeholder="e.g., Festival, Concert" />
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Venue</label>
                    <input name="venueKeyword" value="@Model.VenueKeyword" class="form-control" placeholder="e.g., City Hall" />
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-semibold">From Date</label>
                    <input name="fromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" type="date" class="form-control" />
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-semibold">To Date</label>
                    <input name="toDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" type="date" class="form-control" />
                </div>

                <div class="col-12 d-flex gap-2">
                    <button class="btn btn-primary px-4" type="submit">Search</button>
                    <a class="btn btn-outline-secondary" asp-action="GuestSearch" asp-controller="Events">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm rounded-4">
        <div class="card-body">
            <h5 class="mb-3">Results</h5>

            @if (Model.Results == null || !Model.Results.Any())
            {
                <div class="alert alert-info mb-0">
                    No events found. Try changing filters.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Event Name</th>
                                <th>Date</th>
                                <th>Venue</th>
                                <th class="text-end">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in Model.Results)
                            {
                                <tr>
                                    <td class="fw-semibold">@e.Title</td>
                                    <td>@e.EventDate.ToString("yyyy-MM-dd")</td>
                                    <td>@e.VenueName</td>
                                    <td class="text-end">
                                        @if (e.IsFull)
                                        {
                                            <span class="badge bg-danger">Full</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Available</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3 text-muted small">
                    Note: Guest view hides ticket quantity, seat types, and pricing details.
                </div>
            }
        </div>
    </div>
</div>
