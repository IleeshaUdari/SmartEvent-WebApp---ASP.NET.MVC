@model SmartEventWeb.Models.Booking
@{
    ViewData["Title"] = "Booking Confirmation";
}

<div class="container py-4">
    <div class="card shadow-sm rounded-4">
        <div class="card-body">
            <h2 class="fw-bold">Booking Confirmed</h2>
            <p class="text-muted mb-4">Your booking has been recorded successfully.</p>

            <ul class="list-group">
                <li class="list-group-item"><b>Event:</b> @Model.Event?.Title</li>
                <li class="list-group-item"><b>Quantity:</b> @Model.Quantity</li>
                <li class="list-group-item"><b>Seat Type:</b> @Model.SeatType</li>
                <li class="list-group-item"><b>Date:</b> @Model.Event?.EventDate.ToString("yyyy-MM-dd")</li>
            </ul>

            <div class="mt-3 d-flex gap-2">
                <a class="btn btn-outline-dark" asp-controller="Home" asp-action="Index">Back Home</a>
                <a class="btn btn-outline-primary" asp-controller="Reviews" asp-action="Index" asp-route-eventId="@Model.EventId">
                    View Reviews
                </a>
            </div>
        </div>
    </div>
</div>
